Subject: [PATCH] Reuse old status_icon_id on taskbar_created_msg

https://github.com/AlienCowEatCake/sylpheed-windows/issues/12
---
 gtk/gtkstatusicon.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/gtk/gtkstatusicon.c b/gtk/gtkstatusicon.c
index 68561fa73f..c094aa1f0d 100644
--- a/gtk/gtkstatusicon.c
+++ b/gtk/gtkstatusicon.c
@@ -728,7 +728,7 @@ wndproc (HWND   hwnd,
 	  }
 
 	  priv->nid.hWnd = hwnd;
-	  priv->nid.uID = status_icon_id++;
+	  /*priv->nid.uID = status_icon_id++;*/
 	  priv->nid.uCallbackMessage = WM_GTK_TRAY_NOTIFICATION;
 	  priv->nid.uFlags = NIF_MESSAGE;
 
